<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include("partials/head") %> 
    <title>Profil</title>
    <link rel="stylesheet" type="text/css" href="/styles/profile.css" />
</head>
<body>
    <div id="infos"><%= user.pseudo %></div>
    <div id="content">
        <div>
            <header id="header"> 
                <nav>
                    <ul>
                        <li><a href="/help">Aide</a></li>
                        <li><a href="/logout">Déconnexion</a></li>
                    </ul>
                </nav>
            </header>
            <% if (typeof alreadyConnected !== "undefined" && alreadyConnected === true) { %> 
                <h2 class="error">Vous êtes déjà connecté</h2>
            <% } %>
            <% if (typeof PWModified !== "undefined" && PWModified === true) { %> 
                <h2 class="information">Mot de passe modifié</h2>
            <% } %>
            <% if (typeof registered !== "undefined" && registered === true) { %> 
                <h2 class="information">Bienvenue, vous pouvez désormais créer votre premier projet, consultez notre <a href="/help">page d'aide</a></h2>
            <% } %>
            <% if (typeof settingsChanged !== "undefined" && settingsChanged === true) { %> 
                <h2 class="information">Paramètres modifiés</a></h2>
            <% } %>
            <% if (typeof pageNotFound !== "undefined" && pageNotFound === true) { %> 
                <h2 class="error">La page n'existe pas</h2>
            <% } %>
        </div>
        <main>
            <h1>Profil</h1>
            <div>
                <div>
                    <h2>Modifier les paramètres du compte</h2>
                    <div class="links">
                        <p><a href="/settings">Paramètres du compte</a></p>
                    </div>
                </div>
            </div>
        </main>
</body>
</html>