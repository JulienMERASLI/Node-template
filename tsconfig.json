{
	"compilerOptions": {
		"target": "es5",
		"jsx": "preserve",
		"moduleResolution": "node",
		"sourceMap": false,
		"lib": ["es2016", "dom"],
		"allowSyntheticDefaultImports": true,
		"watch": true,
		"typeRoots": ["./types", "./node_modules/@types/"]
	},
	"exclude": [
		"node_modules",
		"**/node_modules/*",
	],
	"compileOnSave": true
}